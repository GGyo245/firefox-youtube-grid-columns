{
  "manifest_version": 2,
  "name": "YouTube Grid Columns Controller",
  "version": "0.1.2",
  "description": "Adjust YouTube video grid columns (2-8) and hide Shorts shelves.",
  "icons": {
    "48": "icon.svg",
    "96": "icon.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "youtube-grid-columns@geegun.dev",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "*://www.youtube.com/*"
  ],
  "browser_action": {
    "default_title": "YT Grid Columns",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
